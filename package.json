{
  "name": "urnway",
  "private": true,
  "workspaces": [
    "urnway-*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace urnway-api run dev",
    "dev:mobile": "npm --workspace urnway-mobile run start",
    "dev:auth-web": "npm --workspace urnway-auth-web run dev",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:push": "npm --workspace urnway-api run db:push",
    "db:studio": "npm --workspace urnway-api run db:studio"
  }
}

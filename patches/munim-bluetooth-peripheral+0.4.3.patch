+RCT_EXPORT_METHOD(updateCharacteristicValue:(NSString *)serviceUuid
+                  characteristicUuid:(NSString *)characteristicUuid
+                  value:(NSString *)value
+                  notify:(BOOL)notify) {
+  if (![serviceUuid isKindOfClass:[NSString class]] ||
+      ![characteristicUuid isKindOfClass:[NSString class]]) {
+    return;
+  }
+
+  CBMutableCharacteristic *characteristic =
+    [self findMutableCharacteristicForServiceUUID:serviceUuid
+                               characteristicUUID:characteristicUuid];
+
+  if (!characteristic) {
+    return;
+  }
+
+  NSData *nextValue = [(value ?: @"") dataUsingEncoding:NSUTF8StringEncoding];
+  characteristic.value = nextValue;
+
+  if (!notify) {
+    return;
+  }
+
+  NSString *key = [self characteristicKeyForServiceUUID:serviceUuid
+                                     characteristicUUID:characteristicUuid];
+  NSArray<CBCentral *> *subscribed = [[self subscribedCentralsForKey:key create:NO] copy];
+  [self.peripheralManager updateValue:nextValue
+                    forCharacteristic:characteristic
+                 onSubscribedCentrals:subscribed.count > 0 ? subscribed : nil];
 }
 

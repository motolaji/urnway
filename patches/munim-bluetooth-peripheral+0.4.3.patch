+  }
+}
+
+- (void)peripheralManagerDidStartAdvertising:(CBPeripheralManager *)peripheral
+                                       error:(NSError *)error {
+  if (error != nil) {
+    self.advertisingRequested = NO;
+    [self emitAdvertisingState:@"failed" errorCode:@(error.code)];
+    return;
+  }
+
+  [self emitAdvertisingState:@"started" errorCode:nil];
+}
+
+- (void)peripheralManager:(CBPeripheralManager *)peripheral
+    didReceiveWriteRequests:(NSArray<CBATTRequest *> *)requests {
+  for (CBATTRequest *request in requests) {
+    NSData *value = request.value ?: [NSData data];
+    NSString *serviceUuid = request.characteristic.service.UUID.UUIDString ?: @"";
+    NSString *characteristicUuid = request.characteristic.UUID.UUIDString ?: @"";
+    CBMutableCharacteristic *characteristic =
+      [self findMutableCharacteristicForServiceUUID:serviceUuid
+                                 characteristicUUID:characteristicUuid];
+    if (characteristic) {
+      characteristic.value = value;
+    }
+
+    NSString *decodedValue =
+      [[NSString alloc] initWithData:value encoding:NSUTF8StringEncoding] ?: @"";
+
+    [self emitEvent:kCharacteristicWriteReceivedEvent
+            payload:@{
+              @"deviceId": request.central.identifier.UUIDString ?: @"unknown",
+              @"serviceUuid": serviceUuid,
+              @"characteristicUuid": characteristicUuid,
+              @"value": decodedValue,
+            }];
+
+    [self.peripheralManager respondToRequest:request withResult:CBATTErrorSuccess];
+  }
+}
+
+- (void)peripheralManager:(CBPeripheralManager *)peripheral
+    central:(CBCentral *)central
+    didSubscribeToCharacteristic:(CBCharacteristic *)characteristic {
+  NSString *serviceUuid = characteristic.service.UUID.UUIDString ?: @"";
+  NSString *characteristicUuid = characteristic.UUID.UUIDString ?: @"";
+  NSString *key =
+    [self characteristicKeyForServiceUUID:serviceUuid characteristicUUID:characteristicUuid];
+  NSMutableArray<CBCentral *> *centrals = [self subscribedCentralsForKey:key create:YES];
+
+  BOOL alreadyPresent = NO;
+  for (CBCentral *existingCentral in centrals) {
+    if ([existingCentral.identifier isEqual:central.identifier]) {
+      alreadyPresent = YES;
+      break;
+    }
+  }
+  if (!alreadyPresent) {
+    [centrals addObject:central];
+  }
+
+  [self emitEvent:kCharacteristicSubscriptionChangedEvent
+          payload:@{
+            @"deviceId": central.identifier.UUIDString ?: @"unknown",
+            @"serviceUuid": serviceUuid,
+            @"characteristicUuid": characteristicUuid,
+            @"subscribed": @YES,
+          }];
+  [self emitEvent:kCentralConnectionStateChangedEvent
+          payload:@{
+            @"deviceId": central.identifier.UUIDString ?: @"unknown",
+            @"state": @"connected",
+          }];
+}
+
+- (void)peripheralManager:(CBPeripheralManager *)peripheral
+    central:(CBCentral *)central
+    didUnsubscribeFromCharacteristic:(CBCharacteristic *)characteristic {
+  NSString *serviceUuid = characteristic.service.UUID.UUIDString ?: @"";
+  NSString *characteristicUuid = characteristic.UUID.UUIDString ?: @"";
+  NSString *key =
+    [self characteristicKeyForServiceUUID:serviceUuid characteristicUUID:characteristicUuid];
+  NSMutableArray<CBCentral *> *centrals = [self subscribedCentralsForKey:key create:NO];
+
+  NSUInteger indexToRemove = NSNotFound;
+  for (NSUInteger index = 0; index < centrals.count; index += 1) {
+    if ([centrals[index].identifier isEqual:central.identifier]) {
+      indexToRemove = index;
+      break;
+    }
+  }
+  if (indexToRemove != NSNotFound) {
+    [centrals removeObjectAtIndex:indexToRemove];
+  }
+
+  [self emitEvent:kCharacteristicSubscriptionChangedEvent
+          payload:@{
+            @"deviceId": central.identifier.UUIDString ?: @"unknown",
+            @"serviceUuid": serviceUuid,
+            @"characteristicUuid": characteristicUuid,
+            @"subscribed": @NO,
+          }];
+  [self emitEvent:kCentralConnectionStateChangedEvent
+          payload:@{
+            @"deviceId": central.identifier.UUIDString ?: @"unknown",
+            @"state": @"disconnected",
+          }];
 }
 
